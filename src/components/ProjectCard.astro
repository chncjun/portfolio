---
export interface Props {
  title: string;
  description: string;
  techStack: string[];
  githubUrl?: string;
  liveUrl?: string;
  image?: string;
}

const { title, description, techStack, githubUrl, liveUrl, image } = Astro.props;
---

<article
  class="group glass flex h-full flex-col overflow-hidden rounded-2xl
         transition-all duration-500
         hover:-translate-y-2 hover:border-primary-500/30
         hover:shadow-2xl hover:shadow-primary-500/10"
>
  <!-- Image / placeholder -->
  <div class="relative h-48 overflow-hidden bg-gradient-to-br from-primary-900/50 to-indigo-900/50">
    {image ? (
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-700
               group-hover:scale-110"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center">
        <svg
          class="h-16 w-16 text-primary-400 opacity-20 transition-all duration-700
                 group-hover:scale-110 group-hover:opacity-30"
          fill="none" stroke="currentColor" viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
      </div>
    )}

    <!-- Bottom gradient fade -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#030014] via-transparent to-transparent opacity-60"></div>

    <!-- Hover overlay with quick-action buttons -->
    <div
      class="absolute inset-0 flex items-center justify-center gap-4
             bg-black/60 opacity-0 transition-opacity duration-300
             group-hover:opacity-100"
    >
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} source code`}
          class="rounded-full bg-white/10 p-3 text-white transition-all
                 duration-200 hover:scale-110 hover:bg-white/20"
        >
          <!-- GitHub icon -->
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8
              8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726
              -4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333
              -1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839
              1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107
              -.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467
              -5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535
              -1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266
              1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404
              2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242
              2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0
              4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823
              2.222v3.293c0 .319.192.694.801.576 4.765-1.589
              8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      )}
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} live demo`}
          class="rounded-full bg-white/10 p-3 text-white transition-all
                 duration-200 hover:scale-110 hover:bg-white/20"
        >
          <!-- External-link icon -->
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0
                     002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <!-- Card body -->
  <div class="flex flex-grow flex-col p-6">
    <h3 class="mb-3 text-xl font-bold text-white transition-colors
               duration-300 group-hover:text-primary-400">
      {title}
    </h3>

    <p class="mb-5 flex-grow text-sm leading-relaxed text-gray-400">
      {description}
    </p>

    <!-- Tech tags -->
    <div class="mb-5 flex flex-wrap gap-2">
      {techStack.map((t) => (
        <span class="rounded-md border border-gray-700/50 bg-gray-800/80
                     px-2.5 py-1 text-xs font-medium text-gray-300">
          {t}
        </span>
      ))}
    </div>

    <!-- Bottom links -->
    <div class="flex items-center gap-5 border-t border-white/5 pt-4">
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-gray-400
                 transition-colors hover:text-primary-400"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8
              8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726
              -4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333
              -1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839
              1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107
              -.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467
              -5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535
              -1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266
              1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404
              2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242
              2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0
              4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823
              2.222v3.293c0 .319.192.694.801.576 4.765-1.589
              8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Source
        </a>
      )}
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-gray-400
                 transition-colors hover:text-primary-400"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0
                     002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Live Demo
        </a>
      )}
    </div>
  </div>
</article>
