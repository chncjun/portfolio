---
const links = [
  { label: 'Home',     href: '#home' },
  { label: 'About',    href: '#about' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact',  href: '#contact' },
];
---

<nav id="navbar" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between md:h-20">

      <!-- Logo -->
      <a href="#home" class="group flex items-center gap-2.5">
        <div
          class="flex h-10 w-10 items-center justify-center rounded-xl
                 bg-gradient-to-br from-primary-500 to-indigo-500
                 font-bold text-white text-lg
                 group-hover:shadow-lg group-hover:shadow-primary-500/25
                 transition-shadow duration-300"
        >
          JC
        </div>
        <span class="hidden text-lg font-semibold text-white sm:block">
          Jun Cui
        </span>
      </a>

      <!-- Desktop Links -->
      <div class="hidden items-center gap-1 md:flex">
        {links.map((l) => (
          <a
            href={l.href}
            class="rounded-lg px-4 py-2 text-sm font-medium text-gray-300
                   hover:bg-white/10 hover:text-white transition-all duration-200"
          >
            {l.label}
          </a>
        ))}
        <a
          href="/resume.pdf"
          target="_blank"
          class="ml-3 rounded-lg bg-primary-600 px-5 py-2 text-sm font-medium
                 text-white hover:bg-primary-500 transition-all duration-200
                 hover:shadow-lg hover:shadow-primary-500/25"
        >
          Resume
        </a>
      </div>

      <!-- Mobile Toggle -->
      <button
        id="menu-toggle"
        class="rounded-lg p-2 text-gray-300 hover:bg-white/10 hover:text-white
               transition-colors md:hidden"
        aria-label="Toggle navigation"
      >
        <svg id="icon-open" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="hidden h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-menu" class="hidden md:hidden">
    <div class="glass mx-4 mb-4 space-y-1 rounded-2xl p-4">
      {links.map((l) => (
        <a
          href={l.href}
          class="mobile-link block rounded-xl px-4 py-3 font-medium text-gray-300
                 hover:bg-white/10 hover:text-white transition-all duration-200"
        >
          {l.label}
        </a>
      ))}
      <a
        href="/resume.pdf"
        target="_blank"
        class="mt-2 block rounded-xl bg-primary-600 px-4 py-3 text-center
               font-medium text-white hover:bg-primary-500 transition-all duration-200"
      >
        Resume
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle  = document.getElementById('menu-toggle')!;
  const drawer  = document.getElementById('mobile-menu')!;
  const iconO   = document.getElementById('icon-open')!;
  const iconC   = document.getElementById('icon-close')!;
  const navbar  = document.getElementById('navbar')!;

  function closeMenu() {
    drawer.classList.add('hidden');
    iconO.classList.remove('hidden');
    iconC.classList.add('hidden');
  }

  toggle.addEventListener('click', () => {
    drawer.classList.toggle('hidden');
    iconO.classList.toggle('hidden');
    iconC.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-link').forEach((a) =>
    a.addEventListener('click', closeMenu)
  );

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-[#030014]/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    } else {
      navbar.classList.remove('bg-[#030014]/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    }
  });
</script>
