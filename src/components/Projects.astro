---
import ProjectCard from './ProjectCard.astro';
import { projects } from '../data/projects';
---

<section id="projects" class="section-padding relative">

  <!-- Ambient glow -->
  <div class="absolute left-1/2 top-0 h-[400px] w-[800px] -translate-x-1/2
              rounded-full bg-primary-600/[0.04] blur-[120px]"></div>

  <div class="relative mx-auto max-w-6xl">

    <!-- Heading -->
    <div class="reveal mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">
        Featured&nbsp;<span class="gradient-text">Projects</span>
      </h2>
      <p class="mx-auto max-w-lg text-gray-400">
        A selection of projects I've built. Each one taught me something new
        and pushed my skills further.
      </p>
      <div class="mx-auto mt-6 h-1 w-20 rounded-full bg-gradient-to-r
                  from-primary-500 to-indigo-500"></div>
    </div>

    <!-- Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project, i) => (
        <div class="reveal" style={`transition-delay:${i * 0.08}s`}>
          <ProjectCard {...project} />
        </div>
      ))}
    </div>
  </div>
</section>
